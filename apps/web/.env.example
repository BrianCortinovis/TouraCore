# TouraCore web app — env template
# Copia questo file in .env.local e popola con valori reali per dev locale.
# Per production, settare in Vercel Dashboard → Project → Settings → Env Variables.
# Lo schema Zod in apps/web/src/env.ts valida queste env al boot in production.

# === Supabase (REQUIRED always) ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Management API token per skill supabase-cloud-ops (no esposto frontend)
SUPABASE_ACCESS_TOKEN=sbp_...

# === Stripe (REQUIRED in production for billing flows) ===
STRIPE_SECRET_KEY=sk_live_...                 # sk_test_ in dev
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...

# === Cron + secrets isolation (REQUIRED in production, ≥32 char) ===
CRON_SECRET=                                  # auth Bearer token Vercel cron
MAGIC_LINK_SECRET=                            # HMAC magic link customer (S013: prod fail-closed)
VOUCHER_JWT_SECRET=                           # HMAC voucher JWT (S012: prod fail-closed)
INTEGRATIONS_ENCRYPTION_KEY=                  # AES key credenziali integration (S011: prod fail-closed)

# === Email Resend (REQUIRED in production) ===
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@touracore.com
RESEND_FROM_EMAIL=noreply@touracore.com

# === Cloudflare R2 storage ===
R2_ACCOUNT_ID=...
R2_ACCESS_KEY_ID=...
R2_SECRET_ACCESS_KEY=...
R2_BUCKET_NAME=touracore
R2_PUBLIC_URL=https://cdn.touracore.com

# === Public URLs (REQUIRED in production) ===
NEXT_PUBLIC_SITE_URL=https://touracore.com
NEXT_PUBLIC_APP_URL=https://touracore.com

# === Analytics ===
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-...

# === AI integrations (optional) ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# === Vendor webhook secrets (optional, per integration) ===
THEFORK_WEBHOOK_SECRET=
GOOGLE_RESERVE_WEBHOOK_SECRET=
OCTORATE_API_BASE=https://api.octorate.com

# === E2E test only ===
TESTSPRITE_BYPASS_RATE_LIMIT=                 # solo per test, mai in prod

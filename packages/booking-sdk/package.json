{
  "name": "@touracore/booking-sdk",
  "version": "0.1.0",
  "description": "SDK headless per integrare il booking engine TouraCore in siti custom. Alternativa nativa all'iframe.",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./react": "./src/react.tsx"
  },
  "scripts": {
    "build": "true",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/node": "^22",
    "typescript": "^5"
  }
}

{
  "name": "touracore",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test:unit": "pnpm -F @touracore/compliance -F @touracore/security -F @touracore/fiscal -F @touracore/pricing -F @touracore/vouchers -F @touracore/partners -F @touracore/billing test",
    "test:e2e": "pnpm --dir apps/web run test:e2e",
    "test:e2e:public": "pnpm --dir apps/web run test:e2e:public",
    "test:e2e:m080": "pnpm --dir apps/web run test:e2e:m080",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit",
    "secrets": "tsx scripts/secrets/gui/server.ts",
    "secrets:cli": "tsx scripts/secrets/menu.ts",
    "secrets:install-app": "bash scripts/secrets/install-app.sh"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1029.0",
    "@clack/prompts": "^1.2.0",
    "@next/eslint-plugin-next": "^16.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "knip": "^6.6.0",
    "tsx": "^4.21.0",
    "turbo": "^2",
    "typescript": "^5",
    "typescript-eslint": "^8.58.1"
  },
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "react-qr-code": "^2.0.18"
  },
  "pnpm": {
    "overrides": {
      "fast-xml-parser@<5.7.0": ">=5.7.0",
      "uuid@<14.0.0": ">=14.0.0",
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
